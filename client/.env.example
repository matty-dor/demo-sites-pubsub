# Leave unset locally so Vite proxies /api to the dev server (see vite.config.ts).
# For Vercel/Netlify production builds, set this to your API origin, e.g.:
# VITE_API_BASE_URL=https://your-api.example.com

# VITE_API_BASE_URL=

# Vercel + Pub/Sub: same-origin path for POST /api/publish (see repo /api/publish.js).
# VITE_PUBLISH_URL=/api/publish
# Or absolute URL to your *deployment* hostname only (from the browser address bar):
# VITE_PUBLISH_URL=https://your-project.vercel.app/api/publish

# Optional shared secret; must match PUBLISH_INGRESS_SECRET in the Vercel project env if set.
# VITE_PUBLISH_INGRESS_SECRET=

# When not "true", mock events + dynamic content + simulated personalization are stored in the
# browser (Redux + localStorage). Set to true to use the Fastify API + Supabase for mock events.
# VITE_USE_BACKEND=true
#
# On Vercel without Fastify: keep VITE_USE_BACKEND unset/false (mock events stay in the browser) and
# set VITE_USE_VERCEL_API=true so POST /api/personalization uses api/personalization.js (secret in
# Vercel env). Avoids 404 on /api/mock-events.
# VITE_USE_VERCEL_API=true
#
# Personalization env (Fastify .env or Vercel server env): PERSONALIZATION_API_BASE_URL,
# PERSONALIZATION_API_PATH_TEMPLATE (must include {{customerId}}), PERSONALIZATION_API_KEY.
#
# GrowthLoop public API (Fastify .env or Vercel server env): GROWTHLOOP_API_TOKEN,
# GROWTHLOOP_API_ACCESS_KEY; optional GROWTHLOOP_API_BASE_URL (default https://app.growthloop.com).

# Optional image URLs for the header (full HTTPS URLs work best).
# VITE_GROWTHLOOP_LOGO_URL=https://...
# VITE_CLIENT_LOGO_URL=https://...

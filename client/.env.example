# Leave unset locally so Vite proxies /api to the dev server (see vite.config.ts).
# For Vercel/Netlify production builds, set this to your API origin, e.g.:
# VITE_API_BASE_URL=https://your-api.example.com

# VITE_API_BASE_URL=

# Option A (Vercel + Confluent): URL for POST /api/publish (see repo /api/publish.js).
# Easiest on Vercel: use a same-origin path so you avoid CORS and wrong hosts:
# VITE_CONFLUENT_PUBLISH_URL=/api/publish
# Or absolute URL to your *deployment* hostname only (from the browser address bar), never vercel.com/dashboard links:
# VITE_CONFLUENT_PUBLISH_URL=https://your-project.vercel.app/api/publish

# Optional shared secret; must match PUBLISH_INGRESS_SECRET in the Vercel project env if set.
# VITE_PUBLISH_INGRESS_SECRET=

# When not "true", mock events + dynamic content + simulated personalization are stored in the
# browser (Redux + localStorage). Set to true to use the Fastify API for those features.
# VITE_USE_BACKEND=true

# Optional image URLs for the header (full HTTPS URLs work best).
# VITE_GROWTHLOOP_LOGO_URL=https://...
# VITE_CLIENT_LOGO_URL=https://...

PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# One Supabase project per demo deployment
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Personalization API (proxied; never exposed to browser)
PERSONALIZATION_API_BASE_URL=
PERSONALIZATION_API_KEY=
# Required for POST body { customerId }. Relative to base URL; must contain {{customerId}}
# Example: v1/profiles/{{customerId}}
PERSONALIZATION_API_PATH_TEMPLATE=

# GrowthLoop public API (proxied via POST /api/growthloop; never exposed to browser)
# Authorization: Bearer token=<secret>, access_key=<access_key>
GROWTHLOOP_API_TOKEN=
GROWTHLOOP_API_ACCESS_KEY=
# GROWTHLOOP_API_BASE_URL=https://app.growthloop.com

# Kafka (KafkaJS / broker protocol). Optional if you publish only via Vercel + Confluent REST
# (see repo /api/publish.js and client VITE_CONFLUENT_PUBLISH_URL).
KAFKA_BROKERS=
KAFKA_TOPIC=
# Optional SASL (e.g. Confluent Cloud)
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL=true
